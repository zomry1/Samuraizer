# ──────────────────────────────────────────────────────────────────────────────
# Samuraizer – environment configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.
# ──────────────────────────────────────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────────────────────────────────────
# "gemini" (default, cloud) or "ollama" (local).
# When set to "ollama", GEMINI_API_KEY is not required.
LLM_PROVIDER=gemini

# REQUIRED when LLM_PROVIDER=gemini — Gemini API key
# (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Ollama settings (only used when LLM_PROVIDER=ollama) ────────────────────
# Ollama API base URL (default: http://localhost:11434)
OLLAMA_URL=http://localhost:11434
# Reasoning model — used for analysis and chat
OLLAMA_MODEL=qwen3:14b
# Embedding model — used for RAG search
OLLAMA_EMBED_MODEL=qwen3-embedding:8b

# OPTIONAL — Telegram bot token (https://t.me/BotFather)
# Only needed if you want to use the Telegram bot.
TELEGRAM_BOT_TOKEN=

# OPTIONAL — GitHub personal access token
# Increases GitHub API rate limit from 60 to 5,000 req/hour.
# Needed only if you analyze many GitHub repos.
GITHUB_TOKEN=

# OPTIONAL — transcriptapi.com key (https://transcriptapi.com/dashboard/api-keys)
# Required only for YouTube video transcript fetching.
TRANSCRIPTAPI=

# OPTIONAL — Backend URL used by the Telegram bot
# Defaults to http://localhost:8000 if not set.
SAMURAIZER_URL=http://localhost:8000

# OPTIONAL — Enable Flask debug mode (auto-reloader, verbose errors)
# Set to "true" only for local development. NEVER enable in production.
FLASK_DEBUG=false
